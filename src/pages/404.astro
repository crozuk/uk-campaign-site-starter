---
import BaseLayout from "@components/layout/BaseLayout.astro";
import Button from "@components/ui/Button.astro";
---

<BaseLayout title="Page not found" description="The page you were looking for could not be found." noIndex={true} pathname="/404/">
  <section>
    <div class="container not-found">
      <span class="eyebrow">404</span>
      <h1>That page is not available.</h1>
      <p class="section-copy">
        It may not exist yet, or it may be disabled in the site configuration for this starter.
      </p>
      <div class="hero__actions">
        <Button href="/" variant="primary">Return home</Button>
        <Button href="/about" variant="secondary">Read the campaign case</Button>
      </div>
    </div>
  </section>
</BaseLayout>
