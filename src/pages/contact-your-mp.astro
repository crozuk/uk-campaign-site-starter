---
import BaseLayout from "@components/layout/BaseLayout.astro";
import MpLookupForm from "@components/mp/MpLookupForm.astro";
import PageHero from "@components/ui/PageHero.astro";
import FeatureGrid from "@components/ui/FeatureGrid.astro";
import { isPageEnabled } from "@lib/visibility";

const disabled = !isPageEnabled("contact-your-mp");

const steps = [
  {
    icon: "map-pin",
    title: "Find the right constituency",
    summary:
      "The Pages Function looks up a postcode, resolves the parliamentary constituency, and returns the current MP in a normalised JSON shape with Parliament links when they are available.",
  },
  {
    icon: "mail",
    title: "Copy the message and choose the contact route",
    summary:
      "The starter gives supporters a suggested subject and body they can copy into the contact route they decide to use.",
  },
];
---

<BaseLayout
  title="Contact your MP"
  description="Use the built-in postcode lookup to find the correct MP and copy a ready-to-adapt message."
  pathname="/contact-your-mp/"
  noIndex={disabled}
>
  <PageHero
    eyebrow="MP contact tool"
    title={disabled ? "This page is currently disabled" : "Contact your MP"}
    summary={
      disabled
        ? "The MP lookup has been turned off in the central site config."
        : "Use the built-in postcode lookup to identify the correct MP, review a suggested message, and copy it into the contact route you want to use."
    }
    actions={disabled ? [] : [{ label: "Back to homepage", href: "/", variant: "secondary" }]}
  />

  {
    !disabled && (
      <section class="page-body">
        <div class="container stack">
          <MpLookupForm
            title="Find your MP by postcode"
            summary="This lookup uses Cloudflare Pages Functions for the API layer while keeping the rest of the site static-first."
          />
          <FeatureGrid items={steps} />
        </div>
      </section>
    )
  }
</BaseLayout>
