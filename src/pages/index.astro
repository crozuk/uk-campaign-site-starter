---
import HeroSection from "@components/sections/HeroSection.astro";
import IssueCardsSection from "@components/sections/IssueCardsSection.astro";
import StatsSection from "@components/sections/StatsSection.astro";
import WhyThisMattersSection from "@components/sections/WhyThisMattersSection.astro";
import ActionCardsSection from "@components/sections/ActionCardsSection.astro";
import MpLookupTeaser from "@components/sections/MpLookupTeaser.astro";
import QuoteSection from "@components/sections/QuoteSection.astro";
import LatestPostsSection from "@components/sections/LatestPostsSection.astro";
import FaqTeaserSection from "@components/sections/FaqTeaserSection.astro";
import CtaBand from "@components/sections/CtaBand.astro";
import BaseLayout from "@components/layout/BaseLayout.astro";
import { getFaqEntries, getFeaturedQuote, getLatestBlogPosts } from "@lib/content";
import { isSectionEnabled } from "@lib/visibility";
import { siteConfig } from "@data/site";

const quote = await getFeaturedQuote();
const latestPosts = await getLatestBlogPosts(3);
const faqEntries = await getFaqEntries(3);
---

<BaseLayout title={siteConfig.campaignName} description={siteConfig.seo.defaultDescription} pathname="/">
  {isSectionEnabled("hero") && <HeroSection />}
  {isSectionEnabled("issueCards") && <IssueCardsSection />}
  {isSectionEnabled("stats") && <StatsSection />}
  {isSectionEnabled("whyThisMatters") && <WhyThisMattersSection />}
  {isSectionEnabled("actionCards") && <ActionCardsSection />}
  {isSectionEnabled("mpLookupTeaser") && <MpLookupTeaser />}
  {isSectionEnabled("quote") && quote && <QuoteSection quote={quote} />}
  {isSectionEnabled("latestPosts") && <LatestPostsSection posts={latestPosts} />}
  {isSectionEnabled("faqTeaser") && <FaqTeaserSection entries={faqEntries} />}
  {isSectionEnabled("ctaBand") && <CtaBand />}
</BaseLayout>
