---
import { siteConfig } from "@data/site";
import { getVisibleNavigationItems } from "@lib/visibility";
import Button from "@components/ui/Button.astro";

const pathname = Astro.url.pathname;
const navigation = getVisibleNavigationItems();
const isCurrentPath = (href: string) => {
  if (href === "/") {
    return pathname === "/";
  }

  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/">
      <span class="eyebrow brand__notice">{siteConfig.demoNotice}</span>
      <span class="brand__name">{siteConfig.campaignName}</span>
      <span class="brand__tagline">{siteConfig.tagline}</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      {
        navigation.map((item) => (
          <a href={item.href} aria-current={isCurrentPath(item.href) ? "page" : undefined}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <Button href={siteConfig.ctas.primary.href} variant="primary">
      {siteConfig.ctas.primary.label}
    </Button>

    <details class="site-menu">
      <summary>
        <span>Menu</span>
        <span class="site-menu__icon" aria-hidden="true">
          <span></span>
          <span></span>
        </span>
      </summary>
      <div class="site-menu__panel">
        <nav class="site-menu__nav" aria-label="Mobile">
          {
            navigation.map((item) => (
              <a href={item.href} aria-current={isCurrentPath(item.href) ? "page" : undefined}>
                {item.label}
              </a>
            ))
          }
        </nav>
        <div class="site-menu__actions">
          <Button href={siteConfig.ctas.primary.href} variant="primary">
            {siteConfig.ctas.primary.label}
          </Button>
        </div>
      </div>
    </details>
  </div>
</header>
