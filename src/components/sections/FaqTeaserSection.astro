---
import Reveal from "@components/motion/Reveal.astro";
import { campaignContent } from "@data/campaign";

const { entries = [] } = Astro.props as {
  entries?: Array<{
    data: {
      question: string;
      summary: string;
    };
  }>;
};
---

{
  entries.length > 0 && (
    <section>
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">{campaignContent.faqTeaser.title}</span>
          <h2>Keep common questions in structured content files</h2>
          <p class="section-copy">{campaignContent.faqTeaser.summary}</p>
        </div>

        <div class="faq-grid">
          {entries.map((entry, index) => (
            <Reveal delay={index * 80}>
              <article class="faq-card surface">
                <h3 class="card__title">{entry.data.question}</h3>
                <p class="muted">{entry.data.summary}</p>
              </article>
            </Reveal>
          ))}
        </div>
      </div>
    </section>
  )
}
