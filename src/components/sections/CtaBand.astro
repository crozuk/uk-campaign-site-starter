---
import Button from "@components/ui/Button.astro";
import Reveal from "@components/motion/Reveal.astro";
import { campaignContent } from "@data/campaign";
---

<section class="cta-band">
  <div class="container">
    <Reveal class="cta-band__panel surface">
      <span class="eyebrow">{campaignContent.ctaBand.eyebrow}</span>
      <h2>{campaignContent.ctaBand.title}</h2>
      <p>{campaignContent.ctaBand.summary}</p>
      <div class="cta-band__actions">
        <Button href={campaignContent.ctaBand.primaryHref} variant="primary">
          {campaignContent.ctaBand.primaryLabel}
        </Button>
        <Button href={campaignContent.ctaBand.secondaryHref} variant="secondary">
          {campaignContent.ctaBand.secondaryLabel}
        </Button>
      </div>
    </Reveal>
  </div>
</section>
