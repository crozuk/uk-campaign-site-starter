---
import BaseLayout from "@components/layout/BaseLayout.astro";
import PageHero from "@components/ui/PageHero.astro";
import CalloutPanel from "@components/ui/CalloutPanel.astro";

const {
  title,
  description,
  eyebrow,
  summary,
  calloutTitle,
  calloutBody,
  calloutTone,
  ctaLabel,
  ctaHref,
  pathname,
} = Astro.props;

const actions = ctaLabel && ctaHref ? [{ label: ctaLabel, href: ctaHref, variant: "primary" as const }] : [];
---

<BaseLayout title={title} description={description} pathname={pathname}>
  <PageHero eyebrow={eyebrow} title={title} summary={summary} actions={actions} />
  <section class="page-body">
    <div class="container page-shell">
      <article class="surface prose content-panel">
        <slot />
      </article>

      {
        calloutTitle &&
          calloutBody && (
            <div class="page-sidebar">
              <CalloutPanel title={calloutTitle} body={calloutBody} tone={calloutTone ?? "soft"} />
            </div>
          )
      }
    </div>
  </section>
</BaseLayout>
